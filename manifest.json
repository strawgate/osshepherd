{
  "manifest_version": 3,
  "name": "CodeRabbit PR Review",
  "description": "Trigger CodeRabbit AI reviews on any public GitHub PR.",
  "version": "1.0",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "https://github.com/*",
    "https://*.githubusercontent.com/*",
    "*://ide.coderabbit.ai/*",
    "https://app.coderabbit.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/pull/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "CodeRabbit PR Review Settings"
  }
}
