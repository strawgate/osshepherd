# CodeRabbit session token (Bearer token from app.coderabbit.ai)
CODERABBIT_SESSION_TOKEN=

# Organization UUID (optional — auto-fetched after login)
CODERABBIT_ORG_ID=

# Full Cookie header value — needed to pass WAF (Cloud Armor) in Node test scripts
# Get this by running: node test-review-flow.js and checking the network tab
CODERABBIT_COOKIE=

# Persistent client ID (optional — auto-generated if omitted)
CODERABBIT_CLIENT_ID=

# Token for test-protocol.js smoke test
TEST_TOKEN=
